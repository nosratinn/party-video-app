<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>Leave a Video Message!</title>
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>

    <!-- SCREEN 1: Welcome / Home -->
    <div id="screen-home" class="screen active">
        <div class="screen-content">
            <div class="emoji-large">🎉</div>
            <h1>Leave Us a<br>Video Message!</h1>
            <p class="subtitle">Press <strong>START</strong> and say hello!</p>
            <div class="start-wrapper">
                <label for="video-capture" id="btn-start" class="btn btn-primary btn-large">
                    START
                </label>
                <input 
                    type="file" 
                    id="video-capture" 
                    accept="video/*" 
                    capture="user"
                    class="hidden-input"
                >
            </div>
            <p class="hint-text">You'll have up to 1 minute to record.<br>A familiar camera screen will open — just tap the red record button!</p>
        </div>
    </div>

    <!-- SCREEN 2: Review / Save or Retry -->
    <div id="screen-review" class="screen">
        <div class="screen-content">
            <h2>Your Video Message</h2>
            <div class="video-preview-container">
                <video id="video-playback" class="video-preview" controls playsinline></video>
            </div>
            <p class="review-hint">Tap play to review your message</p>
            <div class="review-buttons">
                <button id="btn-save" class="btn btn-success btn-large">
                    <span class="btn-icon">✅</span> Send Video
                </button>
                <button id="btn-retry" class="btn btn-secondary btn-large">
                    <span class="btn-icon">🔄</span> Try Again
                </button>
            </div>
        </div>
    </div>

    <!-- SCREEN 3: Saving -->
    <div id="screen-saving" class="screen">
        <div class="screen-content">
            <div class="spinner"></div>
            <h2>Saving Your Message...</h2>
            <p class="subtitle">Please wait a moment</p>
        </div>
    </div>

    <!-- SCREEN 4: Thank You -->
    <div id="screen-thankyou" class="screen">
        <div class="screen-content">
            <div class="emoji-large">🎉</div>
            <h1>Thank You!</h1>
            <p class="subtitle">Your message has been saved!</p>
            <div class="emoji-row">🥳 ❤️ 🎊</div>
        </div>
    </div>

    <!-- SCREEN 5: Error -->
    <div id="screen-error" class="screen">
        <div class="screen-content">
            <div class="emoji-large">😕</div>
            <h2>Something went wrong</h2>
            <p class="subtitle" id="error-message">Please try again.</p>
            <button id="btn-error-home" class="btn btn-primary btn-large">
                Go Back
            </button>
        </div>
    </div>

    <script src="js/app.js"></script>
</body>
</html>
